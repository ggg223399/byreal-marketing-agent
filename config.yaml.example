# Copy to config.yaml and fill in your webhook URLs

data_source:
  # 可选数据源：
  #   mock         — 本地测试用假数据，无需 API Key
  #   twitterapi_io — 按量计费 $0.15/1K tweets，适合初期（https://twitterapi.io）
  #   twitter_v2   — 官方 Twitter API v2，Bearer Token，需要 Basic($100/月) 或以上套餐
  type: twitterapi_io
  api_key: ""  # 通过 DATA_SOURCE_API_KEY 环境变量覆盖

monitoring:
  accounts_tier1:
    - "@solana"
    - "@aave"
    - "@realJames333"
  accounts_partners:
    - "@elonmusk"
  keywords:
    - "DeFi"
    - "liquidity"
    - "yield"
    - "rwa"
  polling_interval_minutes: 10

classification:
  model: "claude-haiku-4-5"
  temperature: 0

notifications:
  urgent_channel: "urgent-signals"
  digest_channel: "daily-digest"
  all_channel: "all-signals"
  discord_webhook_url: "<your-all-signals-webhook>"
  digest_webhook_url: "<your-daily-digest-webhook>"  # Discord webhook URL for #daily-digest channel
  urgent_webhook_url: "<your-urgent-signals-webhook>"  # Discord webhook URL for #urgent-signals channel
  digest_time: "23:00"
  digest_timezone: "Asia/Shanghai"

governance:
  max_replies_per_hour: 5
  max_replies_per_day: 20
  blacklist:
    - "@spam_account"
  risk_keywords:
    - "lawsuit"
    - "hack"
    - "rug"
